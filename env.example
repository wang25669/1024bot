# ── 必填 ──────────────────────────────────────────────────────────────────
# Telegram Bot Token，从 @BotFather 获取
BOT_TOKEN=

# 你的 Telegram 用户 ID，从 @userinfobot 获取
# 只有这个 ID 的用户才能操作 Bot；填 0 则不限制
ALLOWED_USER_ID=0

# ── 可选 ──────────────────────────────────────────────────────────────────
# 下载文件存放路径（宿主机目录），默认当前目录下的 download 文件夹
DOWNLOAD_PATH=./download

# 每日任务每次操作的帖子数量上限（实际随机 10~该值）
DAILY_LIKE_COUNT=10
